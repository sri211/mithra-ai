{
  "manifest_version": 3,
  "name": "Mithra Auto-Apply",
  "version": "1.0.0",
  "description": "One-click job applications on LinkedIn, Naukri, and company career sites — filled from your Mithra resume, submitted in your own logged-in browser.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": [
    "https://api.mithraai.in/*",
    "https://mithraai.in/*",
    "https://www.mithraai.in/*",
    "http://*/*",
    "https://*/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Mithra Auto-Apply"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://mithraai.in/*", "https://www.mithraai.in/*",
        "https://*.google.com/*", "https://accounts.google.com/*",
        "https://mail.google.com/*", "https://*.youtube.com/*"
      ],
      "js": ["fillers/engine.js", "content.js"],
      "css": ["content.css"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mithraai.in/*", "https://www.mithraai.in/*"],
      "js": ["auth-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
